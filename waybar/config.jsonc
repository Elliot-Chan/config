      "format": "{name}: {icon}",
      "format-icons": {
        "1": "’äĀ",
        "2": "’ē©",
        "3": "’äĪ",
        "4": "’å╝",
        "5": "’üĄ",
        "urgent": "’ü¬",
        "focused": "’åÆ",
        "default": "’äæ"
      }
    },
    "sway/mode": {
      "format": "<span style=\"italic\">{}</span>"
    },
    "modules-center": [
      "sway/window"
    ],
    "modules-right": [],
    // "tray"
    // "custom/weather"
    // "cpu",
    // "custom/notification",
    // "custom/clock"
    //],
    "custom/clock": {
      "exec": "date +%T",
      "interval": 1,
      "format": "{}",
      "format-alt": "{}"
    },
    "custom/weather": {
      "interval": 3600,
      "format": "{} ",
