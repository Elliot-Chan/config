{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elliot.local/schemas/cangjie-doc-index.schema.json",
  "title": "Cangjie Documentation Index",
  "description": "Schema for searchable Cangjie API documentation records.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "records"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Schema version for the exported index format.",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Index generation time in ISO 8601 format."
    },
    "language": {
      "type": "string",
      "default": "cangjie",
      "description": "Primary language of the index."
    },
    "records": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/record"
      }
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "file",
        "line",
        "column"
      ],
      "properties": {
        "file": {
          "type": "string",
          "minLength": 1
        },
        "line": {
          "type": "integer",
          "minimum": 1
        },
        "column": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "param": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": [
            "string",
            "null"
          ]
        },
        "doc_md": {
          "type": [
            "string",
            "null"
          ]
        },
        "default_md": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "fqname",
        "kind",
        "package",
        "module",
        "display",
        "signature",
        "summary_md",
        "params",
        "deprecated",
        "aliases"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "Stable unique identifier. Prefer a non-URL identifier."
        },
        "language": {
          "type": "string",
          "default": "cangjie"
        },
        "kind": {
          "type": "string",
          "enum": [
            "package",
            "module",
            "struct",
            "class",
            "interface",
            "enum",
            "trait",
            "object",
            "typealias",
            "function",
            "method",
            "constructor",
            "property",
            "field",
            "constant",
            "variable"
          ]
        },
        "category": {
          "type": "string",
          "enum": [
            "package",
            "module",
            "type",
            "callable",
            "value"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Unqualified symbol name."
        },
        "fqname": {
          "type": "string",
          "minLength": 1,
          "description": "Fully qualified symbol name."
        },
        "package": {
          "type": "string",
          "minLength": 1
        },
        "module": {
          "type": "string",
          "minLength": 1
        },
        "display": {
          "type": "string",
          "minLength": 1,
          "description": "UI-friendly label."
        },
        "signature": {
          "type": "string",
          "minLength": 1
        },
        "summary_md": {
          "type": "string",
          "description": "Short summary markdown."
        },
        "details_md": {
          "type": [
            "string",
            "null"
          ],
          "description": "Long-form markdown body."
        },
        "params": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/param"
          }
        },
        "returns_md": {
          "type": [
            "string",
            "null"
          ]
        },
        "examples_md": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "doc_url": {
          "type": [
            "string",
            "null"
          ],
          "description": "Stable relative or absolute URL for the rendered docs."
        },
        "since": {
          "type": [
            "string",
            "null"
          ]
        },
        "deprecated": {
          "type": "boolean"
        },
        "deprecated_message_md": {
          "type": [
            "string",
            "null"
          ]
        },
        "aliases": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "visibility": {
          "type": "string",
          "enum": [
            "public",
            "protected",
            "internal",
            "private"
          ]
        },
        "arity": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0,
          "description": "Number of positional parameters when relevant."
        },
        "overload_key": {
          "type": [
            "string",
            "null"
          ],
          "description": "Stable overload discriminator when one name maps to multiple callables."
        },
        "source": {
          "$ref": "#/$defs/source"
        },
        "search_text": {
          "type": [
            "string",
            "null"
          ],
          "description": "Precomputed text blob for search indexing."
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "enum": [
                  "function",
                  "method",
                  "constructor"
                ]
              }
            }
          },
          "then": {
            "required": [
              "name"
            ]
          }
        }
      ]
    }
  }
}
